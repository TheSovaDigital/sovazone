    }
    .username-grid-refined .username-price{
      font-size:14px;
      line-height:1.1;
      color:#fff;
      font-weight:700;
      white-space:nowrap;
      text-align:right;
      flex:0 0 auto;
    }
    .username-grid-refined .username-buy{
