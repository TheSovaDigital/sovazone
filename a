  <script>
    (function () {
      const grid = document.getElementById('latest-articles-grid');
      if (!grid) return;

      function escapeHtml(str) {
        return String(str || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function normalizePost(post) {
        return {
          slug: post.slug || '',
          title: (post.title || 'Без названия').trim(),
          description: (post.description || post.excerpt || post.shortDescription || '').trim(),
          cover: (post.cover || post.image || post.thumbnail || post.preview || '/og-image.png').trim(),
          date: post.date || ''
        };
      }

      function sortPosts(posts) {
        return [...posts].sort((a, b) => {
          const dateA = new Date(a.date || 0).getTime();
          const dateB = new Date(b.date || 0).getTime();
          return dateB - dateA;
        });
      }

      function cleanDescription(text) {
        let clean = String(text || '')
          .replace(/[«»"“”„‟'`<>\[\]{}*_~^|→←↔↗↘]/g, ' ')
          .replace(/\s+/g, ' ')
          .trim();

        if (!clean) clean = 'Открыть последнюю публикацию из блога SovaZone.';

        if (clean.length > 160) {
          clean = clean.slice(0, 160).trimEnd();
          const lastPunct = Math.max(clean.lastIndexOf('.'), clean.lastIndexOf('!'), clean.lastIndexOf('?'));
          if (lastPunct >= 80) {
            clean = clean.slice(0, lastPunct + 1);
          } else {
            clean = clean.replace(/[,:;\-–—]+$/g, '').trimEnd() + '…';
          }
        } else if (clean.length < 80) {
          const tail = ' Открыть материал в блоге SovaZone.';
          if ((clean + tail).length <= 160) clean += tail;
          if (!/[.!?…]$/.test(clean)) clean += '.';
        }

        return clean;
      }

      function buildPostUrl(slug) {
        return '/post.html?slug=' + encodeURIComponent(slug || '');
      }

      function render(posts) {
        const items = posts.slice(0, 4);
        grid.innerHTML = items.map(post => {
          const title = escapeHtml(post.title);
          const desc = escapeHtml(cleanDescription(post.description));
          const cover = escapeHtml(post.cover || '/og-image.png');
          const href = escapeHtml(buildPostUrl(post.slug));
          return `
            <article class="latest-article-card">
              <div class="latest-article-image-wrap">
                <img class="latest-article-image" src="${cover}" alt="${title}">
              </div>
              <div class="latest-article-body">
                <h3 class="latest-article-title">${title}</h3>
                <p class="latest-article-desc">${desc}</p>
                <a class="latest-article-link" href="${href}">Открыть статью</a>
              </div>
            </article>
          `;
        }).join('');
      }

      function renderFallback() {
        grid.innerHTML = `
          <article class="latest-article-card">
            <div class="latest-article-image-wrap"></div>
            <div class="latest-article-body">
              <h3 class="latest-article-title">Не удалось загрузить блог</h3>
              <p class="latest-article-desc">Открой раздел блога SovaZone, чтобы посмотреть последние публикации.</p>
              <a class="latest-article-link" href="/blog.html">Открыть блог</a>
            </div>
          </article>
        `;
      }

      async function fetchJsonWithFallback(paths) {
        for (const url of paths) {
          try {
            const response = await fetch(url, { cache: 'no-store' });
            if (response.ok) return await response.json();
          } catch (e) {}
        }
        throw new Error('BLOG_INDEX_NOT_FOUND');
      }

      (async function init() {
        try {
          const cacheBust = Date.now();
          const posts = await fetchJsonWithFallback([
            '/content/blog/index.json?v=' + cacheBust,
            'https://cdn.jsdelivr.net/gh/TheSovaDigital/sovazone@main/content/blog/index.json?v=' + cacheBust,
            'https://raw.githubusercontent.com/TheSovaDigital/sovazone/main/content/blog/index.json?v=' + cacheBust
          ]);

          const normalized = sortPosts((Array.isArray(posts) ? posts : []).map(normalizePost))
            .filter(post => post.slug && post.title);

          if (!normalized.length) throw new Error('BLOG_EMPTY');
          render(normalized);
        } catch (e) {
          renderFallback();
        }
      })();
    })();
  </script>
