      min-height:32px;
      height:32px;
      border-radius:11px;
      border:none;
      background:linear-gradient(90deg,#8c52ff,#ff6d6d);
      color:#fff;
      font-size:14px;
      font-weight:600;
      line-height:1;
      text-decoration:none;
      display:flex;
      align-items:center;
      justify-content:center;
