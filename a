      white-space:nowrap;
    }
    .username-grid-refined .username-buy:hover{
      filter:brightness(1.04);
      transform:translateY(-1px);
      color:#fff;
    }

    .projects-work-wrap{
      display:grid;
      grid-template-columns:minmax(0,1fr) 360px;
      gap:18px;
      margin-top:26px;
      align-items:stretch;
    }
    .home-projects,
    .home-about{
      position:relative;
      overflow:hidden;
      border-radius:24px;
      padding:22px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.018)),
        linear-gradient(135deg, rgba(35,39,74,.18), rgba(0,0,0,0));
      border:1px solid rgba(255,255,255,.07);
      min-height:100%;
      height:100%;
      box-sizing:border-box;
    }
    .home-projects{
      display:flex;
      flex-direction:column;
      gap:16px;
    }
    .home-about{
      display:flex;
      flex-direction:column;
    }
    .home-projects::before,
    .home-about::before{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background:linear-gradient(135deg, rgba(255,255,255,.04), rgba(255,255,255,0) 42%);
    }
    .home-projects > *,
    .home-about > *{
      position:relative;
      z-index:1;
    }
    .home-projects .section-head{
      margin-bottom:0;
    }
    .home-projects .section-head h2{
      margin:0;
    }

    .projects-grid{
      display:grid;
      grid-template-columns:repeat(3, minmax(0,1fr));
      gap:12px;
      margin-bottom:0;
      align-items:stretch;
      grid-auto-rows:1fr;
    }
    .project-card{
      display:flex;
      flex-direction:column;
      min-height:188px;
      padding:16px;
      border-radius:18px;
      border:1px solid rgba(255,255,255,.06);
      background:rgba(255,255,255,.02);
      gap:12px;
      box-sizing:border-box;
    }
    .project-card h3{
      margin:0 0 8px;
      font-size:18px;
      line-height:1.14;
      letter-spacing:-.02em;
      color:#fff;
    }
    .project-card p{
      margin:0;
      font-size:14px;
      line-height:1.6;
      color:rgba(255,255,255,.72);
      flex:1 1 auto;
    }
    .project-link{
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      height:44px;
      min-height:44px;
      max-height:44px;
      padding:0 10px;
      border-radius:14px;
      text-decoration:none;
      color:#fff;
      border:1px solid rgba(255,255,255,.09);
      background:rgba(255,255,255,.032);
      width:100%;
      font-weight:700;
      font-size:12px;
      line-height:1;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      box-sizing:border-box;
      margin-top:auto;
      flex:0 0 44px;
      transition:border-color .18s ease, background .18s ease, transform .18s ease;
    }
    .project-link:hover{
      border-color:rgba(255,255,255,.14);
      background:rgba(255,255,255,.04);
      transform:translateY(-1px);
      color:#fff;
    }

    .work-inline{
      margin-top:0;
      flex:1 1 auto;
      display:flex;
      flex-direction:column;
    }
    .work-inline-title{
      margin:0 0 12px;
      color:#fff;
    }
    .steps-grid{
      display:grid;
      grid-template-columns:repeat(4, minmax(0,1fr));
      gap:12px;
      align-items:stretch;
    }
    .step{
      padding:14px;
      border-radius:16px;
      border:1px solid rgba(255,255,255,.06);
      background:rgba(255,255,255,.02);
      min-height:128px;
      box-sizing:border-box;
    }
    .step-head{
      display:flex;
      align-items:center;
      gap:10px;
      margin-bottom:10px;
      min-height:30px;
    }
    .step-num{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:28px;
      height:28px;
      border-radius:999px;
      border:1px solid rgba(217,179,140,.24);
      color:#d9b38c;
      font-size:12px;
      font-weight:700;
      flex:0 0 28px;
    }
    .step h3{
      margin:0;
      font-size:16px;
      line-height:1.16;
      color:#fff;
      letter-spacing:-.02em;
    }
    .step p{
      margin:0;
      font-size:13px;
      line-height:1.58;
      color:rgba(255,255,255,.72);
    }

    .about-title{
      margin:0 0 12px;
      color:#fff;
    }
    .about-text{
      margin:0 0 12px;
      font-size:14px;
      line-height:1.72;
      color:rgba(255,255,255,.74);
    }
    .about-btn{
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      min-height:46px;
      height:46px;
      padding:0 18px;
      border-radius:14px;
      text-decoration:none;
      color:#fff;
      border:1px solid rgba(255,255,255,.09);
      background:linear-gradient(90deg, rgba(131,58,180,.18) 0%, rgba(193,53,132,.16) 38%, rgba(225,48,108,.14) 68%, rgba(247,119,55,.14) 100%);
      box-shadow:inset 0 0 0 1px rgba(255,255,255,.04);
      font-weight:700;
      width:100%;
      margin-top:auto;
      box-sizing:border-box;
      line-height:1.1;
      white-space:nowrap;
      overflow:hidden;
      transition:transform .18s ease, background .18s ease, border-color .18s ease;
    }
    .about-btn:hover{
      transform:translateY(-1px);
      background:linear-gradient(90deg, rgba(131,58,180,.24) 0%, rgba(193,53,132,.22) 38%, rgba(225,48,108,.20) 68%, rgba(247,119,55,.20) 100%);
      border-color:rgba(255,255,255,.14);
      color:#fff;
    }

    @media (max-width:1240px){
      .hero-content h1{
        white-space:normal;
      }
      .hero-actions-row{
        grid-template-columns:repeat(2, minmax(0,1fr));
      }
      .username-grid.username-grid-refined{
        grid-template-columns:repeat(2, minmax(0,1fr));
      }
      .projects-grid{
        grid-template-columns:1fr;
      }
      .steps-grid{
        grid-template-columns:repeat(2, minmax(0,1fr));
      }
      .projects-work-wrap{
        grid-template-columns:1fr;
      }
      .project-link{
        font-size:13px;
      }
    }

    @media (max-width:860px){
      .hero.hero-split{
        flex-direction:column;
      }
      .hero-side{
        width:100%;
        max-width:320px;
      }
      .hero-actions-row{
        grid-template-columns:1fr;
      }
    }

    @media (max-width:680px){
      .hero-content h1{
        white-space:normal;
      }
      .username-grid.username-grid-refined,
      .steps-grid{
        grid-template-columns:1fr;
      }
      .home-projects,
      .home-about{
        padding:18px;
      }
    }


