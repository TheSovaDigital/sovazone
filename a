      line-height:1.02;
      letter-spacing:-.024em;
      color:#fff;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      font-weight:800;
    }
    .username-grid-refined .username-meta{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      min-width:0;
    }
    .username-grid-refined .username-link{
      min-width:0;
      display:block;
      font-size:12px;
      line-height:1.25;
      color:rgba(255,255,255,.68);
