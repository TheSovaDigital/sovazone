  <style>
    .home-page{
      position:relative;
      overflow:hidden;
      padding-top:30px;
    }
    .home-page::before,
    .home-page::after{
      content:"";
      position:absolute;
      pointer-events:none;
      z-index:0;
    }
    .home-page::before{
      top:20px;
      left:-220px;
      width:440px;
      height:440px;
      background:radial-gradient(circle, rgba(128,45,106,.11) 0%, rgba(128,45,106,0) 74%);
      filter:blur(28px);
    }
    .home-page::after{
      top:120px;
      right:-240px;
      width:560px;
      height:560px;
      background:radial-gradient(circle, rgba(34,58,154,.10) 0%, rgba(34,58,154,0) 76%);
      filter:blur(34px);
    }
    .page-content > .container{
      position:relative;
      z-index:1;
    }

    .hero.hero-split{
      margin-bottom:24px;
      align-items:flex-start;
      gap:24px;
    }
    .hero-side{
      display:flex;
      flex-direction:column;
      gap:12px;
      width:min(290px, 100%);
      flex:0 0 290px;
    }
    .hero-badge-wrap{
      margin-bottom:0;
    }
    .hero-badge.hero-badge-static{
      min-height:0;
      padding:9px 16px;
      border-radius:999px;
      font-size:12px;
      line-height:1;
      font-weight:600;
      letter-spacing:.02em;
      background:rgba(255,255,255,.022);
      border:1px solid rgba(217,179,140,.14);
      box-shadow:none;
    }
    .hero-logo-card{
      overflow:hidden;
      aspect-ratio:1 / 1;
      border-radius:26px;
      border:none;
      background:transparent;
      backdrop-filter:none;
      -webkit-backdrop-filter:none;
      box-shadow:none;
    }
    .hero-logo{
      width:100%;
      height:100%;
      object-fit:cover;
      object-position:center;
      display:block;
      border-radius:26px;
    }
    .hero-content{
      min-width:0;
      flex:1 1 auto;
    }
    .hero-content h1{
      margin:0 0 12px;
      font-size:clamp(24px, 1.72vw, 32px);
      line-height:1.04;
      letter-spacing:-0.04em;
      white-space:nowrap;
      max-width:100%;
    }
    .hero-text-block{
      max-width:100%;
    }
    .hero-actions-row{
      display:grid;
      grid-template-columns:repeat(3, minmax(150px, 1fr)) minmax(220px, 1.12fr);
      gap:10px;
      align-items:stretch;
      margin-top:42px;
    }
    .hero-actions-row .btn,
    .hero-actions-row .mini-point{
      min-height:36px;
      height:36px;
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      width:100%;
      box-sizing:border-box;
      padding:0 14px;
      line-height:1.1;
      white-space:nowrap;
      overflow:hidden;
    }
    .hero-actions-row .mini-point{
      border-radius:0;
    }
    .hero-actions-row .btn-telegram{
      border-radius:14px;
    }
    .hero-side-actions{
      display:none;
    }
    .hero-actions-row .btn-telegram{
      color:#fff;
      background:linear-gradient(90deg,#833ab4 0%, #c13584 38%, #e1306c 68%, #f77737 100%);
      border:none;
      box-shadow:0 14px 30px rgba(0,0,0,.18);
      text-decoration:none;
      font-weight:700;
    }
    .hero-actions-row .btn-telegram:hover{
      color:#fff;
      filter:brightness(1.03);
      transform:translateY(-1px);
    }

    .section-head h2,
    .section-head-inline h2,
    .home-projects .section-head h2,
    .about-title,
    .work-inline-title{
